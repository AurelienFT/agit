#!/usr/bin/env bash
# scripts/agit-run — run an Agit agent locally against a labeled GitHub issue.
#
# Trust model:
#   This script runs on YOUR machine, using YOUR authenticated `claude` CLI.
#   No API key passes through GitHub. No model credential ever leaves this host.
#   Anthropic's terms apply to your local Claude Code usage just like any other
#   interactive session — that's the whole point of going through `claude` here
#   rather than an API key wired into a workflow.
#
# Usage:
#   ./scripts/agit-run <issue-number>     # run the agent matching the issue's label
#   ./scripts/agit-run --list             # list open issues with an agit:* label
#   ./scripts/agit-run --help

set -euo pipefail

# ─── argv ────────────────────────────────────────────────────────────────────
case "${1:-}" in
  ""|--help|-h)
    cat <<EOF
Usage:
  $(basename "$0") <issue-number>     run the agent matching the issue's label
  $(basename "$0") --list             list open agit-labeled issues
  $(basename "$0") --help             show this message

This script delegates the actual code generation to your local \`claude\` CLI
(authenticated however you authenticate it — Pro/Max OAuth, Bedrock, Vertex,
or anything Claude Code supports). It then runs the post-flight policy check
that mirrors the future agit-core::policy engine, runs the agent's allowed
commands, and opens a PR via the gh CLI.

Requirements on this machine:
  - cargo, gh, jq, python3
  - claude (Claude Code) installed and authenticated
EOF
    exit 0
    ;;
esac

# ─── pre-flight: required CLIs ───────────────────────────────────────────────
need() { command -v "$1" >/dev/null 2>&1 || { echo "ERR: '$1' is required but not on PATH." >&2; exit 1; }; }
need cargo
need gh
need jq
need python3
need git
need claude

# ─── build agit-cli quietly so we can use `agit show` / `agit validate` ──────
cargo build -q -p agit-cli

# ─── --list ──────────────────────────────────────────────────────────────────
if [ "$1" = "--list" ]; then
  gh issue list \
    --search 'label:"agit:test" label:"agit:doc" label:"agit:feature" state:open' \
    --json number,title,labels \
    --jq '.[] | "#\(.number)\t[\(.labels | map(.name) | map(select(startswith("agit:"))) | join(","))]\t\(.title)"' \
    | column -ts $'\t'
  exit 0
fi

ISSUE="$1"
[[ "$ISSUE" =~ ^[0-9]+$ ]] || { echo "ERR: issue number must be numeric (got: $ISSUE)" >&2; exit 1; }

# ─── fetch the issue + pick its agit:* label ─────────────────────────────────
echo "→ Fetching issue #$ISSUE..."
ISSUE_JSON=$(gh issue view "$ISSUE" --json number,title,body,labels)
ISSUE_TITLE=$(jq -r '.title' <<<"$ISSUE_JSON")
ISSUE_BODY=$(jq -r '.body'  <<<"$ISSUE_JSON")
LABEL=$(jq -r '.labels[].name | select(startswith("agit:"))' <<<"$ISSUE_JSON" | head -1)

if [ -z "$LABEL" ]; then
  echo "ERR: issue #$ISSUE has no agit:* label." >&2
  echo "     Add agit:test, agit:doc, or agit:feature to trigger an agent." >&2
  exit 1
fi

# ─── map label → agent + tool/write constraints (mirrors .agit/agents.yaml) ──
case "$LABEL" in
  agit:test)
    AGENT=test_writer
    BRANCH_PREFIX="agit/test-writer/"
    WRITE_GLOBS='crates/*/tests/**,crates/*/src/**/*.rs,crates/*/Cargo.toml'
    ALLOWED_TOOLS='Read,Edit,Write,Bash(cargo test:*),Bash(cargo check:*),Bash(cargo fmt:*)'
    ALLOWED_COMMANDS='cargo test,cargo check,cargo fmt --check'
    ;;
  agit:doc)
    AGENT=doc_updater
    BRANCH_PREFIX="agit/doc-updater/"
    WRITE_GLOBS='**/*.md,docs/**'
    ALLOWED_TOOLS='Read,Edit,Write'
    ALLOWED_COMMANDS=''
    ;;
  agit:feature)
    AGENT=feature_engineer
    BRANCH_PREFIX="agit/feature/"
    WRITE_GLOBS='crates/**/src/**,crates/**/tests/**,crates/**/Cargo.toml,Cargo.toml'
    ALLOWED_TOOLS='Read,Edit,Write,Bash(cargo build:*),Bash(cargo test:*),Bash(cargo check:*),Bash(cargo fmt:*),Bash(cargo clippy:*)'
    ALLOWED_COMMANDS='cargo build,cargo test,cargo check,cargo fmt --check,cargo clippy'
    ;;
  *)
    echo "ERR: label '$LABEL' is not mapped to an agent in this script." >&2
    exit 1
    ;;
esac

./target/debug/agit show "$AGENT" >/dev/null

PROMPT_PATH=".agit/prompts/${AGENT}.md"
[ -f "$PROMPT_PATH" ] || { echo "ERR: prompt $PROMPT_PATH not found" >&2; exit 1; }

# ─── create the working branch on top of the default branch ─────────────────
DEFAULT_BRANCH=$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name')
BRANCH="${BRANCH_PREFIX}issue-${ISSUE}"

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "ERR: working tree is not clean. Commit/stash before running." >&2
  exit 1
fi

echo "→ Checking out $DEFAULT_BRANCH and pulling..."
git fetch --quiet
git checkout --quiet "$DEFAULT_BRANCH"
git pull --quiet --ff-only

echo "→ Creating branch $BRANCH"
git checkout --quiet -B "$BRANCH"

# ─── build the prompt: system prompt from .agit/prompts + issue context ─────
PROMPT_FILE=$(mktemp -t agit-prompt.XXXXXX)
trap 'rm -f "$PROMPT_FILE"' EXIT
{
  cat "$PROMPT_PATH"
  printf '\n---\nIssue context:\n\nTitle: %s\n\nBody:\n%s\n' "$ISSUE_TITLE" "$ISSUE_BODY"
} > "$PROMPT_FILE"

# ─── invoke Claude Code locally ─────────────────────────────────────────────
# `--print` runs Claude Code headlessly: reads the prompt, runs to completion,
# exits. Authentication is whatever `claude` already has on this host.
#
# `--allowedTools` restricts what Claude can do this turn. Flag name has
# varied across Claude Code versions; if you hit "unknown option", swap it
# for `--allowed-tools` or check `claude --help`.
echo "→ Invoking Claude Code as agent '$AGENT' (label $LABEL)..."
claude --print --allowedTools "$ALLOWED_TOOLS" < "$PROMPT_FILE"

# ─── post-flight policy check (mirrors future agit-core::policy) ────────────
echo
echo "→ Policy check on resulting diff..."
CHANGED=$(git diff --name-only)
if [ -z "$CHANGED" ]; then
  echo "WARN: Claude Code produced no changes. Aborting (branch left for inspection)."
  exit 0
fi

ALLOWED_GLOBS="$WRITE_GLOBS" python3 - <<'PYEOF'
import fnmatch, os, sys, subprocess
allowed = [p for p in os.environ["ALLOWED_GLOBS"].split(",") if p]
forbidden = [".env", ".env.*", "**/.env", "**/.env.*",
             "Cargo.lock", "package-lock.json", "pnpm-lock.yaml", "yarn.lock",
             ".git/**", "**/secrets/**"]
diff = subprocess.check_output(["git", "diff", "--name-only"], text=True).splitlines()
violations = []
for path in diff:
    if any(fnmatch.fnmatch(path, p) for p in forbidden):
        violations.append((path, "forbidden by default"))
        continue
    if not any(fnmatch.fnmatch(path, p) for p in allowed):
        violations.append((path, "outside allowed write globs"))
if violations:
    print("PolicyViolation: the following changes are not permitted:")
    for path, why in violations:
        print(f"  - {path}  ({why})")
    print(f"\nAllowed globs were: {allowed}")
    sys.exit(2)
print(f"OK. {len(diff)} changed file(s) — all within policy.")
PYEOF

# ─── run the agent's allowed commands ───────────────────────────────────────
if [ -n "$ALLOWED_COMMANDS" ]; then
  echo
  echo "→ Running allowed commands..."
  IFS=',' read -ra cmds <<< "$ALLOWED_COMMANDS"
  for cmd in "${cmds[@]}"; do
    echo "  \$ $cmd"
    # shellcheck disable=SC2086
    $cmd
  done
fi

# ─── commit, push, open PR ──────────────────────────────────────────────────
echo
echo "→ Committing & pushing..."
git add -A
git commit -q -m "agit($AGENT): work on issue #$ISSUE"
git push -q -u origin "$BRANCH"

# Build the PR body in a temp file. We do NOT use a heredoc inside $(...) here
# because bash's parser mis-handles apostrophes inside $(<<EOF ... EOF) and
# bails with "unexpected EOF while looking for matching `''".
PR_BODY_FILE=$(mktemp -t agit-pr-body.XXXXXX)
trap 'rm -f "$PROMPT_FILE" "$PR_BODY_FILE"' EXIT
{
  printf '## Agit run\n\n'
  printf 'Agent: `%s`\n' "$AGENT"
  printf 'Provider: `claude_code` (local_command — ran on `%s`)\n' "$(hostname)"
  printf 'Triggered by: Issue #%s\n' "$ISSUE"
  printf 'Policy: Passed (write globs + deny-by-default)\n\n'
  # `printf '---\n\n'` would be misparsed: bash's printf sees `--` as the
  # options terminator. Pass the dashes as an argument instead.
  printf '%s\n\n' '---'
  printf 'This PR was generated by a **local** Agit run on %s.\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  printf 'No model credential transited through Agit Cloud or GitHub Actions; Claude Code\n'
  printf 'was invoked locally using whatever authentication that machine had.\n\n'
  printf 'A human review is required before merge.\n'
} > "$PR_BODY_FILE"

echo "→ Opening PR..."
gh pr create \
  --title "agit($AGENT): work on #$ISSUE" \
  --body-file "$PR_BODY_FILE" \
  --base  "$DEFAULT_BRANCH" \
  --head  "$BRANCH"

gh issue comment "$ISSUE" --body "Agit run completed locally for agent \`$AGENT\`. A PR has been opened (see this repo)."

echo
echo "✓ Done."

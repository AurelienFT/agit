#!/usr/bin/env bash
# scripts/agit-retry — re-run the original developer agent on a PR that the
# reviewer rejected.
#
# Triggered by the watcher when a PR carries the `agit:retry` label. The
# label is consumed (removed) as the first action. The original developer
# agent is identified by parsing the branch name:
#
#     agit/test-writer/issue-12      → test_writer
#     agit/doc-updater/issue-12      → doc_updater
#     agit/feature/issue-12          → feature_engineer
#
# The prompt the agent receives bundles:
#   - its system prompt (.agit/prompts/<agent>.md)
#   - the original issue title + body
#   - the PR title + body
#   - the *latest* review feedback from the reviewer agent
#   - the current diff vs the base branch
#
# After Claude produces a new diff, the policy check + allowed commands run
# the same way as in scripts/agit-run. On success, the new commits are
# pushed to the existing PR branch and the agit:review label is re-added
# (handing the PR back to the reviewer).
#
# Trust model: same as agit-run. Local claude, local auth, no API key.

set -euo pipefail

# ─── argv ────────────────────────────────────────────────────────────────────
case "${1:-}" in
  ""|--help|-h)
    cat <<EOF
Usage:
  $(basename "$0") <pr-number>

Re-runs the original developer agent on a PR. Requires the PR to carry the
\`agit:retry\` label (the watcher only triggers us when it does).
EOF
    exit 0
    ;;
esac

PR=$1
[[ "$PR" =~ ^[0-9]+$ ]] || { echo "ERR: PR number must be numeric (got: $PR)" >&2; exit 1; }

# ─── pre-flight ──────────────────────────────────────────────────────────────
need() { command -v "$1" >/dev/null 2>&1 || { echo "ERR: '$1' is required but not on PATH." >&2; exit 1; }; }
need cargo
need gh
need jq
need git
need python3
need claude

cargo build -q -p agit-cli

# ─── fetch PR state ──────────────────────────────────────────────────────────
echo "→ Fetching PR #$PR..."
PR_JSON=$(gh pr view "$PR" --json number,title,body,headRefName,baseRefName,labels,state,reviews)
STATE=$(jq -r '.state' <<<"$PR_JSON")
HEAD=$(jq -r '.headRefName' <<<"$PR_JSON")
BASE=$(jq -r '.baseRefName' <<<"$PR_JSON")
PR_TITLE=$(jq -r '.title' <<<"$PR_JSON")
PR_BODY=$(jq -r '.body' <<<"$PR_JSON")
HAS_RETRY=$(jq -r '.labels[]?.name | select(. == "agit:retry")' <<<"$PR_JSON")

if [ "$STATE" != "OPEN" ]; then
  echo "PR #$PR is $STATE — nothing to retry."
  exit 0
fi
if [ -z "$HAS_RETRY" ]; then
  echo "PR #$PR is missing the agit:retry label — skipping."
  exit 0
fi

# ─── consume the trigger label first ─────────────────────────────────────────
echo "→ Consuming agit:retry label..."
gh pr edit "$PR" --remove-label "agit:retry"

# ─── resolve the agent from the branch name ──────────────────────────────────
case "$HEAD" in
  agit/test-writer/*)
    AGENT=test_writer
    WRITE_GLOBS='crates/*/tests/**,crates/*/src/**/*.rs,crates/*/Cargo.toml'
    ALLOWED_TOOLS='Read,Edit,Write,Bash(cargo test:*),Bash(cargo check:*),Bash(cargo fmt:*)'
    ALLOWED_COMMANDS='cargo test,cargo check,cargo fmt --check'
    ;;
  agit/doc-updater/*)
    AGENT=doc_updater
    WRITE_GLOBS='**/*.md,docs/**'
    ALLOWED_TOOLS='Read,Edit,Write'
    ALLOWED_COMMANDS=''
    ;;
  agit/feature/*)
    AGENT=feature_engineer
    WRITE_GLOBS='crates/**/src/**,crates/**/tests/**,crates/**/Cargo.toml,Cargo.toml'
    ALLOWED_TOOLS='Read,Edit,Write,Bash(cargo build:*),Bash(cargo test:*),Bash(cargo check:*),Bash(cargo fmt:*),Bash(cargo clippy:*)'
    ALLOWED_COMMANDS='cargo build,cargo test,cargo check,cargo fmt --check,cargo clippy'
    ;;
  *)
    echo "ERR: cannot resolve agent from branch '$HEAD'. Expected agit/<slug>/issue-<N>." >&2
    exit 1
    ;;
esac

PROMPT_PATH=".agit/prompts/${AGENT}.md"

# ─── extract the latest reviewer feedback ────────────────────────────────────
# We want the most recent CHANGES_REQUESTED review body. Fall back to the
# latest review of any kind if none requested changes.
REVIEW_FEEDBACK=$(jq -r '
  [.reviews[]? | select(.state == "CHANGES_REQUESTED")] as $cr
  | if ($cr | length) > 0 then ($cr | last | .body)
    else ([.reviews[]?] | last | .body // "")
    end' <<<"$PR_JSON")

if [ -z "$REVIEW_FEEDBACK" ] || [ "$REVIEW_FEEDBACK" = "null" ]; then
  echo "WARN: no review feedback found on PR #$PR — running anyway."
  REVIEW_FEEDBACK="(no explicit feedback found; please re-check the PR scope)"
fi

# ─── try to find the original issue from the PR body ─────────────────────────
# scripts/agit-run writes "Triggered by: Issue #N" into the PR body.
ISSUE_NUM=$(echo "$PR_BODY" | grep -oE 'Issue #[0-9]+' | head -1 | grep -oE '[0-9]+' || true)
ISSUE_TITLE=""
ISSUE_BODY=""
if [ -n "$ISSUE_NUM" ]; then
  ISSUE_JSON=$(gh issue view "$ISSUE_NUM" --json title,body 2>/dev/null || echo '{}')
  ISSUE_TITLE=$(jq -r '.title // ""' <<<"$ISSUE_JSON")
  ISSUE_BODY=$(jq -r '.body // ""' <<<"$ISSUE_JSON")
fi

# ─── clone PR branch into isolated workspace ─────────────────────────────────
REPO=$(gh repo view --json nameWithOwner --jq '.nameWithOwner')
WORKSPACE=$(mktemp -d -t agit-retry.XXXXXX)
PROMPT_FILE=$(mktemp -t agit-retry-prompt.XXXXXX)
trap 'rm -rf "$WORKSPACE"; rm -f "$PROMPT_FILE"' EXIT

echo "→ Cloning $REPO @ $HEAD into $WORKSPACE..."
gh repo clone "$REPO" "$WORKSPACE/repo" -- --depth=100 >/dev/null 2>&1
cd "$WORKSPACE/repo"
git fetch --quiet origin "$HEAD" "$BASE"
git checkout --quiet "$HEAD"

git config user.name  "agit-runner[bot]"
git config user.email "agit-runner@users.noreply.github.com"

# ─── build the prompt with full context ──────────────────────────────────────
[ -f "$PROMPT_PATH" ] || { echo "ERR: $PROMPT_PATH missing in this clone" >&2; exit 1; }

{
  cat "$PROMPT_PATH"
  printf '\n---\n'
  printf 'This is a RETRY pass on an existing PR (#%s).\n' "$PR"
  printf 'The reviewer agent requested changes; address them and push fixes.\n\n'
  if [ -n "$ISSUE_NUM" ]; then
    printf 'Original issue #%s:\nTitle: %s\n\nBody:\n%s\n\n' "$ISSUE_NUM" "$ISSUE_TITLE" "$ISSUE_BODY"
  fi
  printf 'Current PR title: %s\n\n' "$PR_TITLE"
  printf 'Current PR body:\n%s\n\n' "$PR_BODY"
  printf 'Latest reviewer feedback (this is what you must address):\n%s\n' "$REVIEW_FEEDBACK"
} > "$PROMPT_FILE"

# ─── invoke claude ───────────────────────────────────────────────────────────
echo "→ Invoking Claude Code as agent '$AGENT' (retry on PR #$PR)..."
claude --print --allowedTools "$ALLOWED_TOOLS" < "$PROMPT_FILE"

# ─── post-flight policy check ────────────────────────────────────────────────
echo
echo "→ Policy check on resulting diff..."
CHANGED=$(git diff --name-only)
if [ -z "$CHANGED" ]; then
  echo "WARN: no changes produced. Re-adding agit:review label so the reviewer can re-evaluate."
  cd - >/dev/null
  gh pr edit "$PR" --add-label "agit:review"
  exit 0
fi

ALLOWED_GLOBS="$WRITE_GLOBS" python3 - <<'PYEOF'
import fnmatch, os, sys, subprocess
allowed = [p for p in os.environ["ALLOWED_GLOBS"].split(",") if p]
forbidden = [".env", ".env.*", "**/.env", "**/.env.*",
             "Cargo.lock", "package-lock.json", "pnpm-lock.yaml", "yarn.lock",
             ".git/**", "**/secrets/**"]
diff = subprocess.check_output(["git", "diff", "--name-only"], text=True).splitlines()
violations = []
for path in diff:
    if any(fnmatch.fnmatch(path, p) for p in forbidden):
        violations.append((path, "forbidden by default"))
        continue
    if not any(fnmatch.fnmatch(path, p) for p in allowed):
        violations.append((path, "outside allowed write globs"))
if violations:
    print("PolicyViolation: the following changes are not permitted:")
    for path, why in violations:
        print(f"  - {path}  ({why})")
    print(f"\nAllowed globs were: {allowed}")
    sys.exit(2)
print(f"OK. {len(diff)} changed file(s) — all within policy.")
PYEOF

# ─── run allowed commands ────────────────────────────────────────────────────
if [ -n "$ALLOWED_COMMANDS" ]; then
  echo
  echo "→ Running allowed commands..."
  IFS=',' read -ra cmds <<< "$ALLOWED_COMMANDS"
  for cmd in "${cmds[@]}"; do
    echo "  \$ $cmd"
    # shellcheck disable=SC2086
    $cmd
  done
fi

# ─── commit & push to the same PR branch ─────────────────────────────────────
echo
echo "→ Committing & pushing follow-up..."
git add -A
git commit -q -m "agit($AGENT): retry on PR #$PR — address reviewer feedback"
git push -q origin "$HEAD"

cd - >/dev/null

# ─── hand back to the reviewer ───────────────────────────────────────────────
echo "→ Re-adding agit:review label so the reviewer evaluates the new state."
gh pr edit "$PR" --add-label "agit:review"
gh pr comment "$PR" --body "Agit \`$AGENT\` pushed a follow-up addressing the previous review. Handing back to \`reviewer\` via label \`agit:review\`."

echo
echo "✓ retry done."
